# Public analytics ID. Safe for the browser.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Newsletter provider. Supported values: beehiiv, mailchimp, resend.
EMAIL_PROVIDER=beehiiv

# Server-only provider secret. Never prefix this with NEXT_PUBLIC_.
EMAIL_PROVIDER_API_KEY=

# Beehiiv publication ID or Mailchimp audience/list ID.
NEWSLETTER_LIST_ID=
BEEHIIV_PUBLICATION_ID=

# Resend-only notification settings, if EMAIL_PROVIDER=resend.
NEWSLETTER_NOTIFY_EMAIL=
RESEND_FROM_EMAIL=
